/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cloudflare-prometheus-exporter",
	"account_id": "cf444ff585db510e7ef672ae3dd231af",
	"main": "src/worker.tsx",
	"compatibility_date": "2025-12-09",
	"compatibility_flags": ["nodejs_compat"],
	"logpush": true,
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"MetricExporter",
				"MetricCoordinator",
				"AccountMetricCoordinator"
			]
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "MetricCoordinator",
				"class_name": "MetricCoordinator"
			},
			{
				"name": "AccountMetricCoordinator",
				"class_name": "AccountMetricCoordinator"
			},
			{
				"name": "MetricExporter",
				"class_name": "MetricExporter"
			}
		]
	},
	"observability": {
		"enabled": true,
		"traces": {
			"enabled": true,
			"head_sampling_rate": 1,
			"destinations": ["grafana-traces"]
		},
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": false,
			"destinations": ["grafana-logs"]
		}
	},
	"kv_namespaces": [
		{
			"binding": "CONFIG_KV",
			"id": "972c22e20c4a42a78591ff8b014328b6"
		}
	],
	"ratelimits": [
		{
			"name": "CF_API_RATE_LIMITER",
			"namespace_id": "1",
			"simple": {
				"limit": 200,
				"period": 10
			}
		}
	],
	"vars": {
		"QUERY_LIMIT": 10000,
		"SCRAPE_DELAY_SECONDS": 300,
		"TIME_WINDOW_SECONDS": 60,
		"METRIC_REFRESH_INTERVAL_SECONDS": 60,
		"LOG_FORMAT": "json",
		"LOG_LEVEL": "info",
		"ACCOUNT_LIST_CACHE_TTL_SECONDS": 600,
		"ZONE_LIST_CACHE_TTL_SECONDS": 1800,
		"SSL_CERTS_CACHE_TTL_SECONDS": 1800,
		"HOST_METRICS_ALLOWLIST": "",
		"HOST_METRICS_DELAY_SECONDS": 60,
		"EXCLUDE_HOST": false,
		"CF_HTTP_STATUS_GROUP": false,
		"METRICS_PATH": "/metrics",
		"DISABLE_UI": false,
		"DISABLE_CONFIG_API": false
	}
}
